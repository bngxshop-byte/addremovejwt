    port = int(os.environ.get("PORT", 65470))
    print(f"🚀 تشغيل السيرفر على المنفذ {port}")
    print("🎯 الهدف: 100,000 مشاهدة")
    print("⚡ السرعة: 500 طلب متوازي")
    print("🌐 انتقل إلى http://localhost:65470")
    
    app.run(host="0.0.0.0", port=port, threaded=True)