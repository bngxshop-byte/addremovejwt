            if (!pid) {
                alert('الرجاء إدخال Player ID');
                return;
            }
            
            document.getElementById('result').innerHTML = '<div style="color: #667eea; text-align: center; padding: 20px;">⏳ جاري بدء العملية...</div>';
            document.getElementById('progress-container').style.display = 'block';
            document.getElementById('progress-bar').style.width = '0%';
            
            fetch('/fast_visit?player_id=' + pid)
                .then(r => r.json())
                .then(data => {
                    currentTaskId = data.task_id;
                    document.getElementById('result').innerHTML = '<div style="color: green;">✅ ' + data.message + '</div>';
                    
                    // بدء تتبع التقدم
                    if (progressInterval) clearInterval(progressInterval);
                    progressInterval = setInterval(checkProgress, 2000);
                    checkProgress();
