                    // بناء نتيجة مفصلة
                    resultHtml += `<h3>حالة المهمة: ${task.status || 'غير معروف'}</h3>`;
                    
                    if (task.status === 'fetching_tokens') {
                        resultHtml += '<p>📥 جاري جلب التوكنات...</p>';
                    } else if (task.status === 'encrypting') {
                        resultHtml += `<p>🔐 جاري التشفير... (${task.tokens_count} توكن)</p>`;
                    } else if (task.status === 'sending') {
                        resultHtml += `<p>🚀 جاري الإرسال: ${task.success || 0} من ${task.target || 100000}</p>`;
                        resultHtml += `<p>📊 النسبة: ${task.success_rate || '0%'}</p>`;
                    } else if (task.status === 'completed') {
                        resultHtml += `<h2 style="color: green;">✅ اكتملت المهمة!</h2>`;
                        resultHtml += `<p>✅ الإرسال الناجح: ${task.final_success || 0}</p>`;
                        resultHtml += `<p>⏱️ الوقت الإجمالي: ${task.total_time ? task.total_time.toFixed(2) : 0} ثانية</p>`;
                        resultHtml += `<p>⚡ السرعة: ${task.visits_per_second ? task.visits_per_second.toFixed(1) : 0} مشاهدة/ثانية</p>`;
                        clearInterval(progressInterval);
                    } else if (task.status === 'error') {
                        resultHtml += `<h2 style="color: red;">❌ خطأ</h2>`;
                        resultHtml += `<p>${task.error || 'حدث خطأ غير معروف'}</p>`;
                        clearInterval(progressInterval);
                    }
                    
                    document.getElementById('result').innerHTML = resultHtml;
                })
                .catch(e => {
                    console.error('Error checking progress:', e);
                });
        }
        </script>
    </body>
    </html>
    """

